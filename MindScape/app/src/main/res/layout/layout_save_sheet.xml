<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/save_pop_bg"
        android:layout_width="350dp"
        android:layout_height="450dp"
        android:src="@drawable/save_pop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_pop_save"
        android:layout_width="209dp"
        android:layout_height="155dp"
        android:layout_marginBottom="4dp"
        android:src="@drawable/save_bt"
        app:layout_constraintBottom_toBottomOf="@id/save_pop_bg"
        app:layout_constraintEnd_toStartOf="@+id/btn_pop_end"
        app:layout_constraintStart_toStartOf="@id/save_pop_bg" />

    <ImageView
        android:id="@+id/btn_pop_end"
        android:layout_width="198dp"
        android:layout_height="159dp"
        android:src="@drawable/end_bt"
        app:layout_constraintBottom_toBottomOf="@id/btn_pop_save"
        app:layout_constraintEnd_toEndOf="@id/save_pop_bg"
        app:layout_constraintStart_toEndOf="@id/btn_pop_save"
        app:layout_constraintTop_toTopOf="@id/btn_pop_save"
        app:layout_constraintVertical_bias="0.52" />

</androidx.constraintlayout.widget.ConstraintLayout>