<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/theme_selection_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/theme_bg">

    <ImageView
        android:id="@+id/theme_title_text"
        android:layout_width="360dp"
        android:layout_height="120dp"
        android:layout_marginTop="20dp"
        android:scaleType="fitCenter"
        android:src="@drawable/theme_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/info_btn"
        android:layout_width="125dp"
        android:layout_height="134dp"
        android:layout_marginTop="88dp"
        android:layout_marginEnd="16dp"
        android:padding="10dp"
        android:src="@drawable/info"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btn_deep_focus"
        android:layout_width="303dp"
        android:layout_height="176dp"
        android:src="@drawable/deep_focus"
        app:layout_constraintBottom_toTopOf="@+id/btn_calm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/theme_title_text"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageView
        android:id="@+id/btn_calm"
        android:layout_width="316dp"
        android:layout_height="187dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/calm"
        app:layout_constraintBottom_toTopOf="@+id/btn_lofi"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_deep_focus" />

    <ImageView
        android:id="@+id/btn_lofi"
        android:layout_width="328dp"
        android:layout_height="189dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/lofi"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.566"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_calm" />

    <ImageView
        android:id="@+id/back_btn"
        android:layout_width="161dp"
        android:layout_height="142dp"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="24dp"
        android:padding="10dp"
        android:src="@drawable/back_bt"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>